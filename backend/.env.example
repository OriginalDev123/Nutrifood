# ============================================
# NUTRIAI BACKEND CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# APPLICATION
# ============================================
APP_NAME=NutriAI
APP_VERSION=1.0.0
ENVIRONMENT=development  # development, staging, production
DEBUG=True

# ============================================
# SERVER
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# DATABASE (POSTGRESQL)
# ============================================
DATABASE_URL=postgresql://nutriai_user:nutriai_pass_dev@postgres:5432/nutriai_db
DB_ECHO=False

# ============================================
# REDIS (CACHE & CELERY BROKER)
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ============================================
# CORS (FRONTEND URLS)
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ============================================
# FILE UPLOAD
# ============================================
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=uploads

# ============================================
# AI SERVICES URLS (INTERNAL)
# ============================================
AI_SERVICE_URL=http://ai_service:8001
AI_VISION_SERVICE_URL=http://ai_service:8001/vision
AI_CHATBOT_SERVICE_URL=http://ai_service:8001/chat
AI_MEAL_PLANNER_SERVICE_URL=http://ai_service:8001/meal-plan

# ============================================
# CELERY (ASYNC TASKS)
# ============================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================
# EXTERNAL APIS (OPTIONAL)
# ============================================
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# MONGODB (OPTIONAL - AI LOGS)
# ============================================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=nutriai_logs

# ============================================
# QDRANT (VECTOR DB FOR RAG)
# ============================================
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO

# ============================================
# EMAIL (OPTIONAL)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@nutriai.com

# ============================================
# AWS S3 (OPTIONAL - PRODUCTION)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=nutriai-uploads
S3_REGION=ap-southeast-1