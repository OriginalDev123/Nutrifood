# AI Service Configuration - NutriAI
# Copy this to .env and fill in your values

# Gemini API Key (get from https://makersuite.google.com/app/apikey)
GOOGLE_API_KEY=your_google_ai_api_key_here

# Gemini Model Configuration
GEMINI_MODEL=gemini-flash-latest
GEMINI_VISION_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=2048

# Image Processing Settings
MAX_IMAGE_SIZE_MB=10              # Maximum upload size
TARGET_IMAGE_SIZE_PX=512          # Target compression size
IMAGE_QUALITY=80                  # JPEG quality (0-100)

# Service Configuration
ENVIRONMENT=development           # development | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# Backend API URL (for future integration)
BACKEND_API_URL=http://backend:8000

# Backend Database Connection (Module 2: Nutrition Search)
BACKEND_DATABASE_URL=postgresql://nutriai_user:nutriai_password@postgres:5432/nutriai_db