# ============================================
# NUTRIAI - GLOBAL ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# GENERAL SETTINGS
# ============================================
ENVIRONMENT=development  # development, staging, production
DEBUG=True
APP_NAME=NutriAI
APP_VERSION=1.0.0

# ============================================
# SERVER (BACKEND DEFAULTS)
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# DATABASE (POSTGRESQL)
# ============================================
POSTGRES_DB=nutriai_db
POSTGRES_USER=nutriai_user
POSTGRES_PASSWORD=nutriai_pass_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://nutriai_user:nutriai_pass_dev@postgres:5432/nutriai_db
DB_ECHO=False

# ============================================
# REDIS (CACHE & BROKER)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ============================================
# JWT & SECURITY
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here
# Deprecated: keep only if a service still reads it
SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ============================================
# FRONTEND URLS & CORS
# ============================================
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ============================================
# FILE UPLOAD
# ============================================
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=uploads

# ============================================
# AI SERVICE URLS (INTERNAL)
# ============================================
AI_SERVICE_URL=http://ai_service:8001
AI_VISION_SERVICE_URL=http://ai_service:8001/vision
AI_CHATBOT_SERVICE_URL=http://ai_service:8001/chat
AI_MEAL_PLANNER_SERVICE_URL=http://ai_service:8001/meal-plan

# ============================================
# AI PROVIDERS (GEMINI)
# ============================================
# Get API key from: https://ai.google.dev/
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_VISION_MODEL=gemini-1.5-pro-vision
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.3

# ============================================
# AI SERVICE SETTINGS
# ============================================
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
RATE_LIMIT_PER_MINUTE=15
RATE_LIMIT_PER_DAY=1500
MAX_IMAGE_SIZE_MB=5
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp
FEATURE_VISION_ENABLED=true
FEATURE_CHATBOT_ENABLED=true
FEATURE_MEAL_PLANNER_ENABLED=true
FEATURE_RECOMMENDATIONS_ENABLED=true

# ============================================
# OPENAI (OPTIONAL)
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# EXTERNAL APIS (OPTIONAL)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# QDRANT (VECTOR DATABASE)
# ============================================
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ============================================
# CELERY (ASYNC TASKS)
# ============================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================
# MONGODB (OPTIONAL - AI LOGS)
# ============================================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=nutriai_logs

# ============================================
# EMAIL (OPTIONAL)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@nutriai.com

# ============================================
# AWS S3 (OPTIONAL - PRODUCTION)
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=nutriai-uploads
S3_REGION=ap-southeast-1

# ============================================
# SENTRY (ERROR TRACKING - OPTIONAL)
# ============================================
SENTRY_DSN=

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json

# ============================================
# DEVELOPMENT HELPERS
# ============================================
BACKEND_DATABASE_URL=postgresql://nutriai_user:nutriai_pass_dev@localhost:5432/nutriai_db
BACKEND_API_URL=http://backend:8000